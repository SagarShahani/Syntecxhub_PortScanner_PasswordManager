import json
import os
from cryptography.fernet import Fernet

FILE = "vault.enc"
KEY_FILE = "key.key"

def generate_key():
    key = Fernet.generate_key()
    with open(KEY_FILE, "wb") as f:
        f.write(key)
    return key


def load_key():
    if not os.path.exists(KEY_FILE):
        return generate_key()
    return open(KEY_FILE, "rb").read()


key = load_key()
cipher = Fernet(key)

def load_data():
    if not os.path.exists(FILE):
        return {}

    with open(FILE, "rb") as f:
        encrypted = f.read()

    if not encrypted:
        return {}

    decrypted = cipher.decrypt(encrypted).decode()
    return json.loads(decrypted)


def save_data(data):
    encrypted = cipher.encrypt(json.dumps(data).encode())

    with open(FILE, "wb") as f:
        f.write(encrypted)

def add_entry():
    site = input("Website: ")
    username = input("Username: ")
    password = input("Password: ")

    data = load_data()
    data[site] = {"username": username, "password": password}

    save_data(data)
    print("[+] Saved successfully")


def view_entries():
    data = load_data()

    if not data:
        print("No data found")
        return

    for site, creds in data.items():
        print(f"\nSite: {site}")
        print(f"Username: {creds['username']}")
        print(f"Password: {creds['password']}")


def delete_entry():
    site = input("Website to delete: ")

    data = load_data()

    if site in data:
        del data[site]
        save_data(data)
        print("[+] Deleted")
    else:
        print("Not found")

def menu():
    while True:
        print("\n--- PASSWORD MANAGER ---")
        print("1. Add")
        print("2. View")
        print("3. Delete")
        print("4. Exit")

        choice = input("Choose: ")

        if choice == "1":
            add_entry()
        elif choice == "2":
            view_entries()
        elif choice == "3":
            delete_entry()
        elif choice == "4":
            break
        else:
            print("Invalid option")


if __name__ == "__main__":
    menu()
